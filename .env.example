# =============================================================================
# Environment Variables - Public Transport Delay Detection
# Copy to .env and adjust values for your environment.
# =============================================================================

# -- PostgreSQL / TimescaleDB -------------------------------------------------
POSTGRES_DB=transit
POSTGRES_USER=transit
POSTGRES_PASSWORD=transit_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# -- Apache Kafka -------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# -- Grafana ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -- Live Transit Data Source -------------------------------------------------
LIVE_API_URL=https://maps.mo-bi.ro/api/busData
LIVE_API_POLL_INTERVAL_SECONDS=10

# -- GTFS Static Feed ---------------------------------------------------------
GTFS_DOWNLOAD_URL=https://gtfs.tpbi.ro/regional/BUCHAREST-REGION.zip

# -- Kafka Topics (auto-created, but listed here for reference) ---------------
KAFKA_TOPIC_LIVE_TELEMETRY=transit-live-telemetry

# -- Flink --------------------------------------------------------------------
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081

# -- Real-Time Analytics ------------------------------------------------------
ANALYTICS_WATERMARK_LAG_SECONDS=15
ANALYTICS_STOP_GEOFENCE_METERS=75
ANALYTICS_TRIP_START_TOLERANCE_MINUTES=20
ANALYTICS_BUNCHING_THRESHOLD_SECONDS=120
ANALYTICS_SERVICE_GAP_THRESHOLD_MINUTES=10
ANALYTICS_FEATURE_WINDOW_MINUTES=15
ANALYTICS_SCHEDULE_TIMEZONE=Europe/Bucharest
ANALYTICS_GTFS_MATCH_INTERVAL_SECONDS=30
ANALYTICS_GTFS_MATCH_LOOKBACK_MINUTES=120
ANALYTICS_GTFS_MATCH_BATCH_SIZE=20
ANALYTICS_GTFS_MATCH_SCHEDULE_TOLERANCE_MINUTES=90

# -- Prediction ---------------------------------------------------------------
PREDICTION_HORIZON_MINUTES=30
PREDICTION_HIGH_DELAY_THRESHOLD_SECONDS=300
PREDICTION_INTERVAL_SECONDS=900
PREDICTION_MODEL_PATH=models/delay_model.joblib
PREDICTION_MODEL_VERSION=local-dev
PREDICTION_CACHE_TTL_SECONDS=300
PREDICTION_CACHE_SIZE=300
