# =============================================================================
# Environment Variables — Public Transport Delay Detection
# Copy to .env and adjust values for your environment.
# =============================================================================

# -- PostgreSQL / TimescaleDB -------------------------------------------------
POSTGRES_DB=transit
POSTGRES_USER=transit
POSTGRES_PASSWORD=transit_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# -- Apache Kafka -------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# -- Grafana ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -- Live Transit Data Source -------------------------------------------------
LIVE_API_URL=https://maps.mo-bi.ro/api/busData
LIVE_API_POLL_INTERVAL_SECONDS=10

# -- GTFS Static Feed ---------------------------------------------------------
GTFS_DOWNLOAD_URL=https://gtfs.tpbi.ro/regional/BUCHAREST-REGION.zip

# -- Kafka Topics (auto-created, but listed here for reference) ---------------
KAFKA_TOPIC_LIVE_TELEMETRY=transit-live-telemetry

# -- Flink --------------------------------------------------------------------
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081
