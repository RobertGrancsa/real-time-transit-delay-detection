{
  "uid": "anomaly-detection",
  "title": "Anomaly Detection",
  "description": "Route bunching alerts, service gap detection, and reliability scoring for Bucharest public transit.",
  "tags": ["transit", "anomaly", "alerts"],
  "timezone": "Europe/Bucharest",
  "editable": true,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "route_type",
        "label": "Vehicle Type",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "query": "SELECT DISTINCT route_type_label AS __text, route_type::text AS __value FROM transit.v_route_types ORDER BY route_type_label",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "route_id",
        "label": "Route",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "query": "SELECT DISTINCT route_short_name AS __text, route_id AS __value FROM transit.v_route_types WHERE route_type IN ($route_type) ORDER BY route_short_name",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Bunching Detection",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Active Bunching Events (Last 30 min)",
      "type": "table",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 1 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT event_time AS \"Time\", route_short_name AS \"Route\", CASE route_type WHEN 0 THEN 'Tram' WHEN 1 THEN 'Metro' WHEN 3 THEN 'Bus' WHEN 11 THEN 'Trolleybus' ELSE 'Other' END AS \"Type\", vehicle_a_id AS \"Vehicle A\", vehicle_b_id AS \"Vehicle B\", gap_seconds AS \"Gap (s)\", ROUND(lat_a::numeric, 5) || ', ' || ROUND(lon_a::numeric, 5) AS \"Location A\", ROUND(lat_b::numeric, 5) || ', ' || ROUND(lon_b::numeric, 5) AS \"Location B\" FROM transit.v_active_bunching WHERE ($__all = '$__all' OR route_id IN ($route_id)) ORDER BY event_time DESC LIMIT 100",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Gap (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 30 },
                    { "color": "yellow", "value": 60 },
                    { "color": "green", "value": 90 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Time", "desc": true }],
        "footer": { "show": true, "reducer": ["count"], "countRows": true }
      }
    },
    {
      "id": 3,
      "title": "Bunching Events Map",
      "type": "geomap",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 1 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT lat_a AS latitude, lon_a AS longitude, route_short_name AS \"Route\", gap_seconds AS \"Gap (s)\", vehicle_a_id || ' ↔ ' || vehicle_b_id AS \"Vehicles\" FROM transit.v_active_bunching WHERE ($__all = '$__all' OR route_id IN ($route_id)) LIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "view": {
          "id": "coords",
          "lat": 44.4268,
          "lon": 26.1025,
          "zoom": 12
        },
        "basemap": { "type": "osm-standard", "name": "OpenStreetMap" },
        "layers": [
          {
            "type": "markers",
            "name": "Bunching",
            "config": {
              "showLegend": true,
              "style": {
                "size": { "fixed": 8 },
                "color": { "fixed": "red" },
                "opacity": 0.85,
                "symbol": { "mode": "fixed", "fixed": "img/icons/marker/triangle.svg" }
              }
            },
            "location": {
              "mode": "coords",
              "latitude": "latitude",
              "longitude": "longitude"
            },
            "tooltip": true
          }
        ],
        "tooltip": { "mode": "details" },
        "controls": { "showZoom": true, "mouseWheelZoom": true, "showAttribution": true }
      }
    },
    {
      "id": 4,
      "title": "Bunching Frequency Over Time (Hourly)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 11 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, route_id AS metric, bunching_count AS \"Events\" FROM transit.cagg_hourly_bunching WHERE bucket BETWEEN $__timeFrom() AND $__timeTo() AND ($__all = '$__all' OR route_id IN ($route_id)) ORDER BY bucket",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max"] }
      }
    },
    {
      "id": 10,
      "title": "Service Gaps",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "Active Service Gap Alerts (Last 60 min)",
      "type": "table",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 21 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT gap_start AS \"Gap Start\", gap_end AS \"Gap End\", route_short_name AS \"Route\", CASE route_type WHEN 0 THEN 'Tram' WHEN 1 THEN 'Metro' WHEN 3 THEN 'Bus' WHEN 11 THEN 'Trolleybus' ELSE 'Other' END AS \"Type\", direction_id AS \"Dir\", gap_duration_min AS \"Duration (min)\", gap_duration_sec AS \"Duration (s)\" FROM transit.v_active_service_gaps WHERE ($__all = '$__all' OR route_id IN ($route_id)) ORDER BY gap_duration_sec DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Duration (min)" },
            "properties": [
              { "id": "unit", "value": "m" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": null },
                    { "color": "orange", "value": 15 },
                    { "color": "red", "value": 30 }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Gap Start" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "Gap End" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Duration (min)", "desc": true }],
        "footer": { "show": true, "reducer": ["count"], "countRows": true }
      }
    },
    {
      "id": 12,
      "title": "Service Reliability Score (Hourly)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 21 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, route_id AS metric, gap_count AS \"Gap Count\" FROM transit.cagg_hourly_reliability WHERE bucket BETWEEN $__timeFrom() AND $__timeTo() AND ($__all = '$__all' OR route_id IN ($route_id)) ORDER BY bucket",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max", "mean"] }
      }
    },
    {
      "id": 13,
      "title": "Total Gap Duration by Route (Hourly)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 31 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, route_id AS metric, ROUND((total_gap_sec / 60.0)::numeric, 1) AS \"Gap Duration (min)\" FROM transit.cagg_hourly_reliability WHERE bucket BETWEEN $__timeFrom() AND $__timeTo() AND ($__all = '$__all' OR route_id IN ($route_id)) ORDER BY bucket",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "m"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
      }
    },
    {
      "id": 14,
      "title": "Most Unreliable Routes",
      "type": "bargauge",
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 31 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(r.route_short_name, rel.route_id) AS metric, SUM(rel.gap_count) AS \"Total Gaps\" FROM transit.cagg_hourly_reliability rel LEFT JOIN transit.routes r ON r.route_id = rel.route_id WHERE rel.bucket BETWEEN $__timeFrom() AND $__timeTo() AND ($__all = '$__all' OR rel.route_id IN ($route_id)) GROUP BY COALESCE(r.route_short_name, rel.route_id) ORDER BY \"Total Gaps\" DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "text",
        "minVizWidth": 8,
        "minVizHeight": 16
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
