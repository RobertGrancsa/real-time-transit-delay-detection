{
  "uid": "delay-analytics",
  "title": "Delay Analytics",
  "description": "Historical delay trends, route comparison, and schedule adherence analysis for Bucharest public transit.",
  "tags": ["transit", "delay", "analytics"],
  "timezone": "Europe/Bucharest",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "route_type",
        "label": "Vehicle Type",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "query": "SELECT DISTINCT route_type_label AS __text, route_type::text AS __value FROM transit.v_route_types ORDER BY route_type_label",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1,
        "sort": 1
      },
      {
        "name": "route_id",
        "label": "Route",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "timescaledb" },
        "query": "SELECT DISTINCT route_short_name AS __text, route_id AS __value FROM transit.v_route_types WHERE route_type IN ($route_type) ORDER BY route_short_name",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Hourly Delay Trends",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Average Delay Over Time (Hourly)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, route_id || COALESCE(' — ' || (SELECT route_short_name FROM transit.routes r WHERE r.route_id = h.route_id), '') AS metric, avg_delay_sec AS \"Avg Delay\" FROM transit.cagg_hourly_delay h WHERE bucket BETWEEN $__timeFrom() AND $__timeTo() AND route_id IN ($route_id) ORDER BY bucket",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 3,
      "title": "Peak Delay Over Time (Hourly)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, route_id AS metric, max_delay_sec AS \"Peak Delay\" FROM transit.cagg_hourly_delay WHERE bucket BETWEEN $__timeFrom() AND $__timeTo() AND route_id IN ($route_id) ORDER BY bucket",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 8,
            "lineWidth": 1,
            "stacking": { "mode": "none" }
          },
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "title": "Vehicles Observed (Hourly)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, route_id AS metric, total_observations AS \"Observations\" FROM transit.cagg_hourly_delay WHERE bucket BETWEEN $__timeFrom() AND $__timeTo() AND route_id IN ($route_id) ORDER BY bucket",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 10,
      "title": "Daily Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "Daily Average Delay by Route",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(r.route_short_name, d.route_id) AS \"Route\", ROUND(AVG(d.avg_delay_sec)::numeric, 1) AS \"Avg Delay (s)\", ROUND(MAX(d.peak_delay_sec)::numeric, 1) AS \"Peak Delay (s)\" FROM transit.cagg_daily_delay d LEFT JOIN transit.routes r ON r.route_id = d.route_id WHERE d.bucket BETWEEN $__timeFrom() AND $__timeTo() AND d.route_id IN ($route_id) GROUP BY COALESCE(r.route_short_name, d.route_id) ORDER BY \"Avg Delay (s)\" DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 12,
      "title": "Daily Delay Heatmap (Route × Day)",
      "type": "state-timeline",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, COALESCE(r.route_short_name, d.route_id) AS metric, d.avg_delay_sec AS \"Delay\" FROM transit.cagg_daily_delay d LEFT JOIN transit.routes r ON r.route_id = d.route_id WHERE d.bucket BETWEEN $__timeFrom() AND $__timeTo() AND d.route_id IN ($route_id) ORDER BY bucket",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 180 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "rowHeight": 0.8,
        "mergeValues": false,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 20,
      "title": "Speed Analysis",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "title": "Hourly Average Speed by Route",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 14, "x": 0, "y": 32 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT bucket AS time, route_id AS metric, avg_speed_kmh AS \"Avg Speed\" FROM transit.cagg_hourly_speed WHERE bucket BETWEEN $__timeFrom() AND $__timeTo() AND route_id IN ($route_id) ORDER BY bucket",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "velocitykmh",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min", "max"] }
      }
    },
    {
      "id": 22,
      "title": "Slowest Routes (Current Period)",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 10, "x": 14, "y": 32 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(r.route_short_name, s.route_id) AS metric, ROUND(AVG(s.avg_speed_kmh)::numeric, 1) AS \"Avg Speed\" FROM transit.cagg_hourly_speed s LEFT JOIN transit.routes r ON r.route_id = s.route_id WHERE s.bucket BETWEEN $__timeFrom() AND $__timeTo() AND s.route_id IN ($route_id) GROUP BY COALESCE(r.route_short_name, s.route_id) ORDER BY \"Avg Speed\" ASC LIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "velocitykmh",
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 12 },
              { "color": "green", "value": 25 }
            ]
          },
          "min": 0,
          "max": 50
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "text",
        "minVizWidth": 8,
        "minVizHeight": 16
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
